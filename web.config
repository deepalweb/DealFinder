<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <add name="iisnode" path="backend/server.js" verb="*" modules="iisnode" />
    </handlers>
    <rewrite>
      <rules>
        <!-- Serve Next.js static files directly -->
        <rule name="NextStaticFiles" stopProcessing="true">
          <match url="^_next/static/(.*)" />
          <action type="Rewrite" url="frontend-next/.next/static/{R:1}" />
        </rule>
        
        <!-- Serve Next.js public files directly -->
        <rule name="NextPublicFiles" stopProcessing="true">
          <match url="^(favicon\.ico|sw\.js|.*\.(png|jpg|jpeg|gif|svg|webp))$" />
          <action type="Rewrite" url="frontend-next/public/{R:0}" />
        </rule>
        
        <!-- API routes go to backend -->
        <rule name="APIRoutes" stopProcessing="true">
          <match url="^api/(.*)" />
          <action type="Rewrite" url="backend/server.js" />
        </rule>
        
        <!-- Node Inspector -->
        <rule name="NodeInspector" patternSyntax="ECMAScript" stopProcessing="true">
          <match url="^backend/server.js\/debug[\/]?" />
        </rule>
        
        <!-- All other requests go to backend (which proxies to Next.js) -->
        <rule name="DynamicContent">
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="True" />
          </conditions>
          <action type="Rewrite" url="backend/server.js" />
        </rule>
      </rules>
    </rewrite>
    <security>
      <requestFiltering>
        <hiddenSegments>
          <remove segment="bin" />
        </hiddenSegments>
      </requestFiltering>
    </security>
    <httpErrors existingResponse="PassThrough" />
    <iisnode watchedFiles="web.config;*.js" />
  </system.webServer>
</configuration>
