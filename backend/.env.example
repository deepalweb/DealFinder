# Database Configuration
# Current database (will be migrated from)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dealfinder?retryWrites=true&w=majority

# New Azure Cosmos DB (MongoDB API) - Add your new connection string here
NEW_MONGO_URI=mongodb+srv://username:password@yourcosmosdb.global.mongocluster.cosmos.azure.com/?tls=true&authMechanism=SCRAM-SHA-256&retrywrites=false&maxIdleTimeMS=120000

# Legacy MongoDB URI (for reference)
MONGODB_URI=mongodb+srv://deepalr:qn7q9Y64AOjrdLbe@cluster0.oybjzf7.mongodb.net/test?retryWrites=true&w=majority&appName=Cluster0

DB_HOST=localhost
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=dealfinder

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here

# Email Configuration (for password reset, notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
M365_EMAIL=your_email@outlook.com

# Google Maps API Key
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google OAuth Configuration
# This must be the Web application OAuth client ID from Google Cloud Console.
# Make sure its Authorized JavaScript origins include your web origins, e.g.
# - http://localhost:3000
# - http://localhost:8080
# - https://dealfinderlk-eafsbyd7ghaph0az.southindia-01.azurewebsites.net
# - https://drstores.lk
GOOGLE_CLIENT_ID=434034339931-01174qocrg92p7f3dck1e46el25nfc56.apps.googleusercontent.com

# Firebase Configuration (for push notifications)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Web Push VAPID Keys (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# Azure Blob Storage Configuration
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your_account_name;AccountKey=your_account_key;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_NAME=dealfinder-images

# Azure OpenAI Configuration
AZURE_OPENAI_RESPONSES_URL=https://your-resource.cognitiveservices.azure.com/openai/responses?api-version=2025-04-01-preview
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com
AZURE_OPENAI_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_MODEL=your_azure_openai_deployment_name
AI_SEARCH_ENABLED=true
AI_PERSONALIZATION_ENABLED=true

# Server Configuration
PORT=3000
NODE_ENV=development

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:3000
